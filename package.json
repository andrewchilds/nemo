{
	"name": "nemo",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"main": "electron/dist/main.cjs",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"electron:build": "tsc -p electron/tsconfig.json && mv electron/dist/main.js electron/dist/main.cjs && mv electron/dist/preload.js electron/dist/preload.cjs",
		"electron:dev": "NODE_ENV=development concurrently \"bun run dev\" \"wait-on http://localhost:5199 && bun run electron:build && ELECTRON_DISABLE_KEYCHAIN_ACCESS=1 electron .\"",
		"electron:start": "bun run build && bun run electron:build && ELECTRON_DISABLE_KEYCHAIN_ACCESS=1 electron .",
		"dist": "bun run build && bun run electron:build && electron-builder",
		"dist:mac": "rm -rf build electron/dist && rm -rf release && bun run build && bun run electron:build && CSC_IDENTITY_AUTO_DISCOVERY=false npx electron-builder --mac dir"
	},
	"devDependencies": {
		"@electron/rebuild": "^4.0.4",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@types/pidusage": "^2.0.5",
		"@vitest/browser-playwright": "^4.1.3",
		"concurrently": "^9.2.1",
		"electron": "^42.0.1",
		"electron-builder": "^26.8.1",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"wait-on": "^9.0.10"
	},
	"dependencies": {
		"electron-serve": "^3.0.1",
		"lucide-svelte": "^1.0.1",
		"node-pty": "^1.1.0",
		"pidusage": "^4.0.1",
		"xterm": "^5.3.0",
		"xterm-addon-fit": "^0.8.0"
	},
	"build": {
		"appId": "com.nemo.processmanager",
		"productName": "Nemo",
		"directories": {
			"output": "release"
		},
		"files": [
			"build/**/*",
			"electron/dist/**/*",
			"node_modules/**/*"
		],
		"mac": {
			"category": "public.app-category.developer-tools",
			"target": [
				"dmg",
				"zip"
			]
		},
		"linux": {
			"target": [
				"AppImage",
				"deb"
			]
		},
		"win": {
			"target": [
				"nsis",
				"portable"
			]
		}
	}
}
